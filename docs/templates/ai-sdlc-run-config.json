{
  "schemaVersion": "1.0",
  "defaultUseCase": "ai-docs/[use-case-slug]",
  "defaultRunner": "codex",
  "runDirectory": "16-agent-runs",
  "defaultReviewer": "Accountable human reviewer",
  "missingSpecPolicy": "fail",
  "defaultVerificationCommands": [
    "[verification command, for example: ./gradlew test]"
  ],
  "stateMachine": {
    "initialStatus": "ready_for_agent",
    "agentStartedStatus": "in_progress",
    "agentFinishedStatus": "agent_execution_finished",
    "agentFailedStatus": "agent_execution_failed",
    "humanReviewStatus": "ready_for_human_review"
  },
  "runners": {
    "codex": {
      "type": "codex",
      "executable": "codex",
      "sandbox": "workspace-write",
      "approvalPolicy": "never",
      "model": null,
      "extraArgs": []
    },
    "claude": {
      "type": "claude",
      "executable": "claude",
      "permissionMode": "acceptEdits",
      "outputFormat": "text",
      "model": null,
      "noSessionPersistence": true,
      "extraArgs": []
    },
    "cursor": {
      "type": "cursor",
      "executable": "cursor-agent",
      "outputFormat": "text",
      "sandbox": "enabled",
      "trustWorkspace": true,
      "force": false,
      "model": null,
      "mode": null,
      "extraArgs": []
    },
    "manual": {
      "type": "manual"
    }
  },
  "commonRequiredSpecs": [
    "README.md",
    "03-specification/feature-ai-spec.yml",
    "03-specification/ai-spec.md",
    "03-specification/role-and-agent-operating-model.md",
    "03-specification/manual-review-and-approval-workflow.md",
    "09-controls/policy-rules.md",
    "09-controls/guardrail-specification.md"
  ],
  "agents": {
    "coding": {
      "displayName": "Coding Agent",
      "aliases": [
        "coding",
        "code",
        "coder"
      ],
      "reviewer": "Software Engineer",
      "requiredSpecs": [
        "10-build/code-generation-plan.md",
        "10-build/ai-test-generation-plan.md"
      ]
    },
    "test": {
      "displayName": "AI Test Agent",
      "aliases": [
        "test",
        "tester",
        "ai-test"
      ],
      "reviewer": "QA / AI Tester",
      "requiredSpecs": [
        "10-build/ai-test-generation-plan.md",
        "11-evaluation/test-cases.md",
        "11-evaluation/evaluation-report.md"
      ]
    },
    "security": {
      "displayName": "Security Review Agent",
      "aliases": [
        "security",
        "security-review"
      ],
      "reviewer": "Security Reviewer",
      "requiredSpecs": [
        "12-security/security-review.md",
        "04-architecture/architecture-pattern.md"
      ]
    }
  }
}
